  <property name="styleSheet">
   <string notr="true">/* ═══ MAIN WINDOW BACKGROUND — Linear Gradient ═══ */
QMainWindow {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #1a3a2e,
        stop:0.4 #2d6b4f,
        stop:1 #0f2419
    );
}

QWidget#centralwidget {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #1a3a2e,
        stop:0.35 #2d6b4f,
        stop:0.7 #3a8a60,
        stop:1 #0f2419
    );
}

/* ═══ WELCOME LABEL ═══ */
QLabel#welcome {
    color: #AAFFC7;
    font-size: 30px;
    font-weight: bold;
    font-family: &quot;Georgia&quot;;
    letter-spacing: 1px;
    background: transparent;
}

/* ═══ WRITE DIARY LABEL ═══ */
QLabel#write_diary{
    color: #AAFFC7;
    font-size: 20px;
    font-family: &quot;Palatino Linotype&quot;;
    font-style: italic;
    letter-spacing: 0.5px;
    background: transparent;
}

/* ═══ TEXT EDIT ═══ */
QTextEdit#textEdit {
    background-color: rgba(255, 255, 255, 0.92);
    border: 2px solid #AAFFC7;
    border-radius: 12px;
    padding: 14px;
    font-size: 13px;
  font-weight: bold;
    font-family: &quot;Segoe UI&quot;;
    color: #1a3a2a;
    selection-background-color: #AAFFC7;
}

QTextEdit#textEdit:focus {
    border: 4px solid #ffffff;
    background-color: rgba(255, 255, 255, 0.97);
}

/* ═══ SAVE BUTTON ═══ */
QPushButton#save_btn {
    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #AAFFC7,
        stop:1 #5ecb8a
    );
    color: #0f2419;
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-family: &quot;Segoe UI&quot;;
    font-weight: bold;
    letter-spacing: 1px;
    min-width: 150px;
    max-width: 150px;
    min-height: 38px;
}

QPushButton#save_btn:hover {
    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #c5ffe0,
        stop:1 #AAFFC7
    );
    color: #0a1f12;
}

QPushButton#save_btn:pressed {
    background-color: #7ad4a8;
    color: #0f2419;
}

/* ═══ MENU BAR ═══ */
QMenuBar {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:0,
        stop:0 #0f2419,
        stop:1 #1a3a2e
    );
    color: #AAFFC7;
    font-family: &quot;Segoe UI&quot;;
    font-size: 13px;
    font-weight: 500;
    padding: 4px 6px;
    border-bottom: 1px solid #AAFFC7;
}

QMenuBar::item {
    padding: 5px 14px;
    background: transparent;
    border-radius: 4px;
}

QMenuBar::item:selected {
    background-color: rgba(170, 255, 199, 0.2);
    color: #ffffff;
}

QMenu {
    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #1a3a2e,
        stop:1 #0f2419
    );
    border: 1px solid #AAFFC7;
    border-radius: 6px;
    color: #AAFFC7;
    font-family: &quot;Segoe UI&quot;;
    padding: 4px;
}

QMenu::item {
    padding: 6px 20px;
    border-radius: 4px;
}

QMenu::item:selected {
    background-color: rgba(170, 255, 199, 0.25);
    color: #ffffff;
}</string>
