  <property name="styleSheet">
   <string notr="true">/* =========================
   MAIN WINDOW - DARK GREEN BACKGROUND
========================= */
QMainWindow {
    background-color: #1a4a2e;
}

QWidget {
    background-color: #1a4a2e;
    font-family: &quot;Segoe UI&quot;, sans-serif;
}

/* =========================
   TITLE LABEL - MEMOVAULT
========================= */
QLabel#titleLabel {
    font-size: 42px;

    font-weight: bold;
    color: #EFFFF6;
    padding: 8px 0px;
    background: transparent;
    qproperty-alignment: AlignCenter;
}

/* =========================
   FIELD LABELS - Username / Password
========================= */
QLabel#usernameLabel,
QLabel#passwordLabel {
    color: rgba(200, 240, 220, 0.85);
    font-size: 13px;
    font-weight: 500;
    background: transparent;
    padding-left: 2px;
}

/* General label fallback */
QLabel {
    color: rgba(200, 240, 220, 0.85);
    font-size: 13px;
    background: transparent;
}

/* =========================
   INPUT FIELDS - WHITE ROUNDED
========================= */
QLineEdit {
    border: none;
    border-radius: 10px;
    padding: 10px 14px;
    background-color: rgba(235, 250, 240, 0.95);
    color: #1b3b2a;
    font-size: 14px;
    selection-background-color: #6EE7A8;
}

QLineEdit:focus {
    border: 2px solid #6EE7A8;
    background-color: #ffffff;
    outline: none;
}

/* =========================
   LOGIN BUTTON - GREEN PILL
========================= */
QPushButton#login_btn {
    background-color: #5DD898;
    color: #0a1f12;
    border: none;
    border-radius: 10px;
    font-size: 15px;
    font-weight: bold;
    min-height: 44px;
    letter-spacing: 0.5px;
}

QPushButton#login_btn:hover {
    background-color: #7EEDB0;
}

QPushButton#login_btn:pressed {
    background-color: #3DC47E;
}

/* =========================
   SHOW PASSWORD BUTTON - INSIDE FIELD
========================= */
QPushButton#showpass_btn {
    background-color: #3DC47E;
    color: #0a1f12;
    border: none;
    border-radius: 6px;
    font-size: 11px;
    font-weight: bold;
    padding: 4px 5px;
    min-height: 12px;
    max-height: 18px;
}

QPushButton#showpass_btn:hover {
    background-color: #5DD898;
}

QPushButton#showpass_btn:pressed {
    background-color: #2FAF6A;
}

/* =========================
   STATUS BAR - BOTTOM DARK
========================= */
QStatusBar {
    background-color: #0d1f14;
    color: #7EEDB0;
    font-size: 12px;
    padding: 4px 8px;
    border-top: 1px solid #1e3d27;
}

QStatusBar::item {
    border: none;
}s</string>
